# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
*.log
*.swp

# Local notebooks / scratch
notebooks/.ipynb_checkpoints/
scratch/
tmp/

# Keep official raw data for reproducibility
!data/raw/
!data/raw/*.xlsx

# Keep final result tables and figures
!outputs/
!outputs/tables/
!outputs/tables/*.csv
!outputs/figures/
!outputs/figures/*.png

# Ignore heavy or temporary output formats if created later
outputs/**/*.pkl
outputs/**/*.joblib
outputs/**/*.npy
outputs/**/*.npz

# Keep empty directory markers only if needed
!.gitkeep

# Generated detailed output files that are archived separately
outputs/tables/robustness_scan_*.csv
outputs/tables/sensitivity_scan_*.csv
outputs/tables/*hourly*.csv
outputs/tables/*hourly_dispatch*.csv
outputs/tables/q4_storage_capacity_scan_hourly.csv
outputs/tables/q4_storage_capacity_scan_summary.csv
outputs/tables/q4_storage_capacity_annual_scan.csv
outputs/figures/sensitivity_*.png
outputs/figures/q4_storage_benefit_per_cost.png
outputs/figures/q4_storage_capacity_scan.png
outputs/figures/q4_storage_annual_tradeoff.png
